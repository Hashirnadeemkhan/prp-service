// Add this to your existing prisma/schema.prisma.
// If starting fresh, include the generator + datasource blocks below.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ── The blog post. Rename to Project / Service / Article etc. if needed. ──
model Blog {
  id        Int      @id @default(autoincrement())
  title     String
  slug      String   @unique
  content   String   // HTML produced by the React Quill editor
  imageUrl  String?  // UploadThing CDN URL
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ── Optional: used only if you add real admin auth (NextAuth credentials). ──
// Store a bcrypt hash in `password`, never plaintext.
model AdminUser {
  id       Int    @id @default(autoincrement())
  username String @unique
  password String
}
